# Copy to .env and fill in real values. Never commit .env.

# Supabase (Tier 1 relational store)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Direct Postgres connection (for db/apply_schema.py and Supabase CLI).
# On IPv4-only networks, use the Session pooler URL — the direct
# db.<ref>.supabase.co host requires IPv6.
SUPABASE_DB_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-<n>-<region>.pooler.supabase.com:5432/postgres
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF

# Pinecone (Tier 2 vector store; 256D matches pipeline.py manifold_dimension)
PINECONE_API_KEY=YOUR-PINECONE-API-KEY
PINECONE_INDEX=annotation
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Anthropic (LLM annotator stage)
ANTHROPIC_API_KEY=

# Optional: alternative provider for the annotator
OPENAI_API_KEY=
